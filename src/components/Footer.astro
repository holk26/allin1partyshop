---
import { useTranslations, type Language } from '@/i18n/translations';

interface Props {
  lang?: Language;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand column -->
      <div>
        <h3 class="text-lg font-extrabold mb-2 text-brand-400">All In One Party Shop</h3>
        <p class="text-sm text-gray-400 italic mb-4">{t.footer.tagline}</p>
        <p class="text-sm text-gray-400 mb-5">{t.footer.description}</p>
        <div class="space-y-1 text-sm text-gray-400">
          <p>
            <a href="mailto:cv@allin1partyshop.com" class="hover:text-white transition-colors focus:outline-none focus:ring-1 focus:ring-brand-500 rounded">
              cv@allin1partyshop.com
            </a>
          </p>
          <p>
            <a href="mailto:cr@allin1partyshop.com" class="hover:text-white transition-colors focus:outline-none focus:ring-1 focus:ring-brand-500 rounded">
              cr@allin1partyshop.com
            </a>
          </p>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-300 mb-4">{t.footer.quickLinks}</h4>
        <ul class="space-y-2">
          <li>
            <a href="/" class="text-sm text-gray-400 hover:text-white transition-colors focus:outline-none focus:ring-1 focus:ring-brand-500 rounded">
              {t.nav.home}
            </a>
          </li>
          <li>
            <a href="/rentals" class="text-sm text-gray-400 hover:text-white transition-colors focus:outline-none focus:ring-1 focus:ring-brand-500 rounded">
              {t.nav.rentals}
            </a>
          </li>
          <li>
            <a href="/about" class="text-sm text-gray-400 hover:text-white transition-colors focus:outline-none focus:ring-1 focus:ring-brand-500 rounded">
              {t.nav.about}
            </a>
          </li>
          <li>
            <a href="/faq" class="text-sm text-gray-400 hover:text-white transition-colors focus:outline-none focus:ring-1 focus:ring-brand-500 rounded">
              {t.nav.faq}
            </a>
          </li>
          <li>
            <a href="/contact" class="text-sm text-gray-400 hover:text-white transition-colors focus:outline-none focus:ring-1 focus:ring-brand-500 rounded">
              {t.nav.contact}
            </a>
          </li>
        </ul>
      </div>

      <!-- Comox Valley -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-300 mb-4">{t.footer.comoxValley}</h4>
        <address class="not-italic text-sm text-gray-400 space-y-1 mb-3">
          <p>861 Shamrock Place</p>
          <p>Comox, BC V9M 4G4</p>
        </address>
        <p class="text-sm text-gray-400 mb-1">
          <a href="tel:2503386678" class="hover:text-white transition-colors">250-338-6678</a>
        </p>
        <div class="mt-3 text-sm text-gray-500 space-y-0.5">
          <p>{t.footer.hours}</p>
          <p>{t.footer.hoursSat}</p>
          <p>{t.footer.hoursSun}</p>
        </div>
      </div>

      <!-- Campbell River -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-300 mb-4">{t.footer.campbellRiver}</h4>
        <address class="not-italic text-sm text-gray-400 space-y-1 mb-3">
          <p>1360 Homewood Road</p>
          <p>Campbell River, BC V9W 6Y5</p>
        </address>
        <p class="text-sm text-gray-400 mb-1">
          <a href="tel:2502878159" class="hover:text-white transition-colors">250-287-8159</a>
        </p>
        <p class="text-sm text-gray-400">
          Emergency: <a href="tel:2502870269" class="hover:text-white transition-colors">250-287-0269</a>
        </p>
        <div class="mt-3 text-sm text-gray-500 space-y-0.5">
          <p>{t.footer.hours}</p>
          <p>{t.footer.hoursSat}</p>
          <p>{t.footer.hoursSun}</p>
        </div>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-8 text-center text-sm text-gray-500">
      <p>&copy; {currentYear} All In One Party Shop. {t.footer.rights}</p>
    </div>
  </div>
</footer>
