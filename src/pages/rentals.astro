---

<Layout
  title="Rental Categories | All In One Party Shop"
  description="Browse all 23 rental categories — tents, tables, chairs, linens, decor, lighting and more. All In One Party Shop serves Vancouver Island since 1994."
>
  <Navigation currentPage="/rentals" />

  <!-- Page Hero -->
  <div class="bg-gray-900 text-white py-16">
    <Container>
      <div class="max-w-2xl">
        <p class="text-brand-400 font-semibold text-sm uppercase tracking-widest mb-3">Our Inventory</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">Rental Categories</h1>
        <p class="text-lg text-gray-300">
          Vancouver Island's largest selection of party and event rentals. Browse all 23 categories below, then visit our full catalogue to build your quote.
        </p>
      </div>
    </Container>
  </div>

  <Section variant="gray">
    <Container>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {categories.map((cat) => (
          <a
            href={cat.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-gray-100 hover:border-brand-200 hover:-translate-y-0.5"
          >
            <div class="aspect-square overflow-hidden">
              <img
                src={cat.img}
                alt={cat.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
            <div class="p-4">
              <h2 class="font-bold text-gray-900 mb-1 group-hover:text-brand-600 transition-colors">
                {cat.name}
              </h2>
              <p class="text-sm text-gray-500">{cat.description}</p>
              <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-600">
                View Items
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-14 text-center bg-white rounded-2xl p-10 shadow-sm border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-3">Can't find what you need?</h2>
        <p class="text-gray-600 mb-6 max-w-lg mx-auto">
          Our catalogue is always growing. Contact us and our team will do their best to source or suggest alternatives for your event.
        </p>
        <a
          href="/contact"
          class="inline-block bg-brand-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-brand-700 transition-colors focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
        >
          Get in Touch
        </a>
      </div>
    </Container>
  </Section>

  <Footer />
</Layout>
