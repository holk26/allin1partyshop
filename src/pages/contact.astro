---
import Layout from '@layouts/Layout.astro';
import Navigation from '@components/Navigation.astro';
import Footer from '@components/Footer.astro';
import Section from '@components/ui/Section.astro';
import Container from '@components/ui/Container.astro';
---

<Layout
  title="Contact Us | All In One Party Shop"
  description="Contact All In One Party Shop — two showroom locations in Comox Valley and Campbell River, Vancouver Island. Get a quote for your next event."
>
  <Navigation currentPage="/contact" />

  <!-- Page Hero -->
  <div class="bg-gray-900 text-white py-16">
    <Container>
      <div class="max-w-2xl">
        <p class="text-brand-400 font-semibold text-sm uppercase tracking-widest mb-3">We'd Love to Help</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">Contact Us</h1>
        <p class="text-lg text-gray-300">
          Visit one of our two showrooms, give us a call, or send us a message. Our team is ready to help you plan your perfect event.
        </p>
      </div>
    </Container>
  </div>

  <!-- Locations -->
  <Section variant="gray">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

        <!-- Comox Valley Card -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100">
          <div class="h-56 overflow-hidden">
            <img
              src="https://allin1partyshop.s3.amazonaws.com/general/IMG_2120.JPG"
              alt="All In One Party Shop Comox Valley showroom area"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-5">📍 Comox Valley Showroom</h2>
            <div class="space-y-3 text-sm">
              <div class="flex gap-3">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <div>
                  <address class="not-italic text-gray-700 font-medium">
                    861 Shamrock Place<br />Comox, BC V9M 4G4
                  </address>
                  <a
                    href="https://maps.google.com/?q=861+Shamrock+Place,+Comox,+BC"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-brand-600 font-medium hover:text-brand-700 transition-colors mt-1 inline-block"
                  >
                    Get Directions →
                  </a>
                </div>
              </div>
              <div class="flex gap-3 items-start">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <div>
                  <p class="text-gray-700 font-medium">Phone</p>
                  <a href="tel:2503386678" class="text-brand-600 hover:text-brand-700 transition-colors">250-338-6678</a>
                </div>
              </div>
              <div class="flex gap-3 items-start">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <div>
                  <p class="text-gray-700 font-medium">Email</p>
                  <a href="mailto:cv@allin1partyshop.com" class="text-brand-600 hover:text-brand-700 transition-colors">cv@allin1partyshop.com</a>
                </div>
              </div>
              <div class="flex gap-3 items-start">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  <p class="text-gray-700 font-medium">Hours</p>
                  <p class="text-gray-600">Mon–Fri 10am–4pm</p>
                  <p class="text-gray-600">Sat by appointment</p>
                  <p class="text-gray-600">Sun closed</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Campbell River Card -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100">
          <div class="h-56 overflow-hidden">
            <img
              src="https://allin1partyshop.s3.amazonaws.com/general/IMG_6565.JPG"
              alt="All In One Party Shop Campbell River marquee tent"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-5">📍 Campbell River Showroom</h2>
            <div class="space-y-3 text-sm">
              <div class="flex gap-3">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <div>
                  <address class="not-italic text-gray-700 font-medium">
                    1360 Homewood Road<br />Campbell River, BC V9W 6Y5
                  </address>
                  <a
                    href="https://maps.google.com/?q=1360+Homewood+Road,+Campbell+River,+BC"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-brand-600 font-medium hover:text-brand-700 transition-colors mt-1 inline-block"
                  >
                    Get Directions →
                  </a>
                </div>
              </div>
              <div class="flex gap-3 items-start">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <div>
                  <p class="text-gray-700 font-medium">Phone</p>
                  <a href="tel:2502878159" class="text-brand-600 hover:text-brand-700 transition-colors">250-287-8159</a>
                  <p class="text-gray-500 mt-1">Emergency: <a href="tel:2502870269" class="text-brand-600 hover:text-brand-700 transition-colors">250-287-0269</a></p>
                </div>
              </div>
              <div class="flex gap-3 items-start">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <div>
                  <p class="text-gray-700 font-medium">Email</p>
                  <a href="mailto:cr@allin1partyshop.com" class="text-brand-600 hover:text-brand-700 transition-colors">cr@allin1partyshop.com</a>
                </div>
              </div>
              <div class="flex gap-3 items-start">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  <p class="text-gray-700 font-medium">Hours</p>
                  <p class="text-gray-600">Mon–Fri 10am–4pm</p>
                  <p class="text-gray-600">Sat by appointment</p>
                  <p class="text-gray-600">Sun closed</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Contact Form -->
  <Section variant="white">
    <Container size="sm">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Send Us a Message</h2>
        <p class="text-gray-600">Tell us about your event and we'll get back to you as soon as possible.</p>
      </div>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="bg-gray-50 rounded-2xl p-8 border border-gray-200 space-y-5"
        novalidate
      >
        <!-- Netlify hidden fields -->
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="first-name" class="block text-sm font-medium text-gray-700 mb-1">First Name <span class="text-brand-600">*</span></label>
            <input
              type="text"
              id="first-name"
              name="first-name"
              required
              autocomplete="given-name"
              class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
              placeholder="Jane"
            />
          </div>
          <div>
            <label for="last-name" class="block text-sm font-medium text-gray-700 mb-1">Last Name <span class="text-brand-600">*</span></label>
            <input
              type="text"
              id="last-name"
              name="last-name"
              required
              autocomplete="family-name"
              class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
              placeholder="Smith"
            />
          </div>
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address <span class="text-brand-600">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
            placeholder="jane@example.com"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            autocomplete="tel"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
            placeholder="250-555-0100"
          />
        </div>

        <div>
          <label for="event-date" class="block text-sm font-medium text-gray-700 mb-1">Event Date (if known)</label>
          <input
            type="date"
            id="event-date"
            name="event-date"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
          />
        </div>

        <div>
          <label for="location" class="block text-sm font-medium text-gray-700 mb-1">Preferred Location</label>
          <select
            id="location"
            name="location"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm bg-white"
          >
            <option value="">Select a showroom…</option>
            <option value="comox-valley">Comox Valley</option>
            <option value="campbell-river">Campbell River</option>
            <option value="either">Either / No preference</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message / Event Details <span class="text-brand-600">*</span></label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm resize-y"
            placeholder="Tell us about your event — type of event, number of guests, items you're interested in, etc."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-brand-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-brand-700 transition-colors focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
        >
          Send Message
        </button>
      </form>
    </Container>
  </Section>

  <Footer />
</Layout>
